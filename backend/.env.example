# =============================================================================
# backend/.env — FastAPI 后端应用读取（pydantic-settings, 前缀 RAG_）
#
# 谁读: uvicorn 启动 app.main 时，app/core/config.py 加载本文件
# 谁不读: docker compose（请配置仓库根目录 .env）
#
# 用法: cp .env.example .env
# =============================================================================
#
# ┌─────────────────────────────────────────────────────────────────────────┐
# │ 快速填写指引                                                            │
# │                                                                         │
# │ 复制本文件为 .env 后，你只需要填以下 4 个值（其余已填好默认值，不用动）： │
# │   1. RAG_MYSQL_PASSWORD  — 与服务器根目录 .env 的 MYSQL_PASSWORD 一致   │
# │   2. RAG_LLM_API_KEY     — 百炼 API Key（DashScope 控制台获取）         │
# │   3. RAG_EMBEDDING_API_KEY — 百炼 API Key（通常与 LLM 相同；mock 可留空）│
# │   4. RAG_RERANK_API_KEY    — 百炼 API Key（通常与 LLM 相同；mock 可留空）│
# │                                                                         │
# │ mock 模式（默认 true）下 API Key 可留空即可跑通链路；接真实服务时：      │
# │   - 填好上述 Key 后将对应 *_MOCK 改为 false                             │
# │                                                                         │
# │ 连远程服务器数据库时（非敏感，但必改）:                                  │
# │   RAG_MYSQL_HOST / RAG_MILVUS_HOST → 改成服务器公网/局域网 IP           │
# │   配完后运行: python scripts/check_connectivity.py（见 docs/DEPLOY.md） │
# └─────────────────────────────────────────────────────────────────────────┘
#
# =============================================================================

# ----- 应用 -----
RAG_APP_NAME=计算机学院智能问答系统
RAG_DEBUG=false
RAG_API_PREFIX=/api
RAG_CORS_ORIGINS=["http://localhost:3000"]

# ----- MySQL -----
# 连本机 docker compose 用 127.0.0.1；连远程服务器改成服务器 IP
RAG_MYSQL_HOST=115.29.220.130
RAG_MYSQL_PORT=3306
RAG_MYSQL_USER=rag_user

# ★ 必填 ★ 填入 MySQL 应用用户密码（须与服务器根目录 .env 中 MYSQL_PASSWORD 完全一致）
RAG_MYSQL_PASSWORD=

RAG_MYSQL_DATABASE=rag_school
RAG_MYSQL_POOL_SIZE=5

# ----- Milvus -----
# 连本机 docker compose 用 127.0.0.1；连远程服务器改成服务器 IP
RAG_MILVUS_HOST=115.29.220.130
RAG_MILVUS_PORT=19530
RAG_MILVUS_COLLECTION=child_chunks
RAG_MILVUS_DIM=1024

# ----- LLM — 百炼 deepseek -----
# ★ 必填（mock 可暂留空）★ 填入百炼 API Key，从 DashScope 控制台获取: https://dashscope.console.aliyun.com/
RAG_LLM_API_KEY=

RAG_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
RAG_LLM_MODEL=deepseek-v4-flash
RAG_LLM_TEMPERATURE=0.3
RAG_LLM_MAX_TOKENS=2048
# true=不调真实 API，留空 Key 也能跑 mock 链路；接真实服务后改为 false
RAG_LLM_MOCK=true

# ----- Embedding — BGE -----
RAG_EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5

# ★ 必填（mock 可暂留空）★ 若走百炼/自建 Embedding API，填入百炼 API Key（通常与 RAG_LLM_API_KEY 相同）
RAG_EMBEDDING_API_KEY=

RAG_EMBEDDING_BASE_URL=
# true=返回 mock 向量；接好服务后改为 false
RAG_EMBEDDING_MOCK=true

# ----- Rerank — qwen3-rerank -----
RAG_RERANK_MODEL=qwen3-rerank

# ★ 必填（mock 可暂留空）★ 填入百炼 API Key（通常与 RAG_LLM_API_KEY 相同），从 DashScope 控制台获取
RAG_RERANK_API_KEY=

RAG_RERANK_BASE_URL=https://dashscope.aliyuncs.com/api/v1/services/rerank/text-rerank/text-rerank
# true=mock 打分；接好服务后改为 false
RAG_RERANK_MOCK=true

# ----- 检索超参 -----
RAG_TOP_K_VECTOR=20
RAG_TOP_K_PARENT=8
RAG_TOP_K_RERANK=5
RAG_HYBRID_VECTOR_WEIGHT=0.6
RAG_HYBRID_LEXICAL_WEIGHT=0.4
RAG_SIBLING_BOOST=0.05
RAG_MIN_SCORE_THRESHOLD=0.35
RAG_FAQ_MATCH_THRESHOLD=0.85
