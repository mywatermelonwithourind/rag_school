# =============================================================================
# 根目录 .env — 仅 docker compose 读取
#
# 谁读: 在仓库根目录执行 `docker compose up -d` 时，Compose 用此文件做变量替换
# 谁不读: backend 应用、前端 — 它们各自有自己的 .env（见 backend/.env.example）
#
# 用法: cp .env.example .env
# =============================================================================
#
# ┌─────────────────────────────────────────────────────────────────────────┐
# │ 快速填写指引                                                            │
# │                                                                         │
# │ 复制本文件为 .env 后，你只需要填以下 4 个值（其余已填好默认值，不用动）： │
# │   1. MYSQL_ROOT_PASSWORD   — MySQL root 强密码（自行设定，勿用弱口令）    │
# │   2. MYSQL_PASSWORD        — 应用用户 rag_user 的密码（自行设定）       │
# │   3. MINIO_ACCESS_KEY        — MinIO 访问密钥（自行设定，≥8 字符）       │
# │   4. MINIO_SECRET_KEY        — MinIO 私密密钥（自行设定，≥8 字符）       │
# │                                                                         │
# │ 填完后: docker compose up -d                                            │
# │ 注意: MYSQL_PASSWORD 须与 backend/.env 的 RAG_MYSQL_PASSWORD 保持一致    │
# └─────────────────────────────────────────────────────────────────────────┘
#
# =============================================================================

# ----- MySQL 容器初始化凭证 -----
MYSQL_DATABASE=rag_school
MYSQL_USER=rag_user

# ★ 必填 ★ 填入 MySQL root 用户的强密码（自行设定，生产务必复杂；无外部获取渠道）
MYSQL_ROOT_PASSWORD=

# ★ 必填 ★ 填入应用用户 rag_user 的密码（自行设定；须与 backend/.env 中 RAG_MYSQL_PASSWORD 一致）
MYSQL_PASSWORD=

# ----- MinIO 对象存储（Milvus 依赖，仅容器内网访问）-----
# backend 不直连 MinIO，无需写入 backend/.env

# ★ 必填 ★ 填入 MinIO Access Key（自行设定，建议 ≥8 字符随机串；无外部控制台）
MINIO_ACCESS_KEY=

# ★ 必填 ★ 填入 MinIO Secret Key（自行设定，建议 ≥16 字符随机串；与上面 Access Key 配对）
MINIO_SECRET_KEY=

# ----- 宿主机端口映射（防火墙需放行这些端口供团队远程连）-----
# 团队成员 backend 的 RAG_MYSQL_PORT / RAG_MILVUS_PORT 须与此一致
MYSQL_HOST_PORT=3306
MILVUS_HOST_PORT=19530
# MinIO Web 控制台（可选，调试对象存储；backend 不需要）
MINIO_CONSOLE_HOST_PORT=9001
